# OpenClaw VPS Deployment - Environment Variables
# Copy to .env and fill in your values:  cp .env.template .env
# Generate secrets with:  openssl rand -hex 32

# === REQUIRED ===
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME
GOG_KEYRING_PASSWORD=CHANGE_ME

# At least one model provider API key
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# === GATEWAY ===
# Pinned to a known-good tag. :latest had a deepseek provider regression
# starting in 2026.4.10 (native deepseek provider missing from catalog);
# 2026.4.8 is the last working version verified for this deployment.
# When upgrading, test with `openclaw infer model providers | grep deepseek`
# before bumping.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.8
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_CONFIG_DIR=/root/.openclaw
OPENCLAW_WORKSPACE_DIR=/root/.openclaw/workspace
XDG_CONFIG_HOME=/home/node/.openclaw

# === CHANNELS (optional) ===
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# === TOOLS (optional) ===
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
